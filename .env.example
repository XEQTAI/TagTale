# Database
DATABASE_URL="postgresql://tagtale:tagtale@localhost:5432/tagtale?schema=public"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Email (Resend - https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="TagTale <noreply@yourdomain.com>"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxx"

# Claude Managed Agents (set after running: npm run agents:setup)
CLAUDE_AGENT_ID="agent_xxxxxxxxxxxxxxxx"
CLAUDE_ENVIRONMENT_ID="env_xxxxxxxxxxxxxxxx"

# App URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Upload directory (relative to project root)
UPLOAD_DIR="public/uploads"
NEXT_PUBLIC_UPLOAD_URL="/uploads"

# Admin secret for initial setup
ADMIN_EMAIL="admin@yourdomain.com"
