# ─── Database ───────────────────────────────────────────────────────────────
# Local: `npm run docker:up` then use the URL below (tagtale/tagtale/tagtale).
# Supabase: Dashboard → Project Settings → Database → Connection string → URI.
#   Use the "Direct connection" host (db.xxxxx.supabase.co:5432), not the pooler, for `prisma db push`.
#   Path is usually /postgres — tables still live in schema "public" (append ?schema=public&sslmode=require).
DATABASE_URL="postgresql://tagtale:tagtale@localhost:5432/tagtale?schema=public"

# ─── JWT Secret (generate: openssl rand -base64 32) ──────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ─── Email (Resend — https://resend.com) ─────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="TagTale <noreply@yourdomain.com>"

# ─── OpenRouter AI (primary — cheap Gemma 4 for moderation & generation) ─────
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxx"
# Model — set to google/gemma-4 when available; falls back to gemma-3-27b
OPENROUTER_MODEL="google/gemma-3-27b-it"

# ─── Anthropic Claude (optional — only for Managed Agents deep moderation) ───
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxx"
CLAUDE_AGENT_ID="agent_xxxxxxxxxxxxxxxx"
CLAUDE_ENVIRONMENT_ID="env_xxxxxxxxxxxxxxxx"

# ─── Supabase (browser OTP login — create project at https://supabase.com) ───
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Server-only: Storage uploads (Dashboard → Settings → API → service_role). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Bucket name in Supabase Storage — create bucket "uploads", keep it **Private** (signed URLs only)
SUPABASE_STORAGE_BUCKET="uploads"

# ─── App ─────────────────────────────────────────────────────────────────────
# Dev server port (must match `npm run dev` — see package.json). Change both if you pick another port.
PORT="3333"
NEXT_PUBLIC_BASE_URL="http://localhost:3333"
# Optional: comma-separated extra origins allowed for Server Actions (prod should include your real site URL)
ALLOWED_ORIGINS=""
ADMIN_EMAIL="admin@yourdomain.com"

# ─── Cloudflare R2 (optional — if set, uploads use R2 before Supabase; cheap storage, S3-compatible) ─
# Dashboard → R2 → Create bucket (private). Create API token with Object Read & Write.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="tagtale-uploads"

# ─── File uploads (local dev fallback only — production uses R2 or Supabase) ─
# UPLOAD_DIR="public/uploads"
