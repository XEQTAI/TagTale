# ─── Database ───────────────────────────────────────────────────────────────
# Supabase — open Dashboard → **Connect** (or Database settings).
#
# If "Can't reach" on db.xxx.supabase.co:5432, use **Session** or **Transaction pooler**
# (**.pooler.supabase.com:6543**) from **Connect** — paste the **entire** copied URI.
# If "Authentication failed" / invalid credentials: reset DB password in Dashboard → Database,
# then paste the **new** URI from Connect (pooler user is often postgres.PROJECT_REF, not only postgres).
#
# Prisma migrations: if you use Transaction pooler for DATABASE_URL, add DIRECT_URL (direct
# connection URI, port 5432) for `prisma migrate` — see Prisma “Supabase” guide. For quick local
# setup you can use `npx prisma db push` instead of migrate.
#
# Test:  npm run db:check
# Apply schema (pick one):    npx prisma migrate deploy   OR   npx prisma db push
# Seed demo admin + data:    npm run db:seed
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&sslmode=require"

# ─── JWT Secret (≥32 chars; generate: openssl rand -base64 32) ───────────────
# Required in production (Netlify → Site settings → Environment variables).
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ─── Email (Resend — https://resend.com) ─────────────────────────────────────
# Local dev: set to re_dev_placeholder to log codes in the terminal instead of sending real email.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="TagTale <noreply@yourdomain.com>"

# ─── OpenRouter AI (primary — cheap Gemma 4 for moderation & generation) ─────
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxx"
# Model — set to google/gemma-4 when available; falls back to gemma-3-27b
OPENROUTER_MODEL="google/gemma-3-27b-it"

# ─── Anthropic Claude (optional — only for Managed Agents deep moderation) ───
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxx"
CLAUDE_AGENT_ID="agent_xxxxxxxxxxxxxxxx"
CLAUDE_ENVIRONMENT_ID="env_xxxxxxxxxxxxxxxx"

# ─── Supabase (Storage + image CDN only — not used for sign-in; email codes use Resend above) ───
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
# Server-only: Storage uploads (Dashboard → Settings → API → service_role). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Bucket name in Supabase Storage — create bucket "uploads", keep it **Private** (signed URLs only)
SUPABASE_STORAGE_BUCKET="uploads"

# ─── Optional: staging API POST /api/auth/preview-login (no UI; set PREVIEW_LOGIN_SECRET) ─

# ─── Optional: emergency admin sign-in API only (POST /api/auth/admin-password) ────────
# Same email as ADMIN_EMAIL must exist in DB with isAdmin=true. No login UI — use email OTP instead.
# ADMIN_PASSWORD="at-least-8-chars-strong-secret"

# ─── App ─────────────────────────────────────────────────────────────────────
# Dev server port (must match `npm run dev` — see package.json). Change both if you pick another port.
PORT="3333"
NEXT_PUBLIC_BASE_URL="http://localhost:3333"
# Optional: comma-separated extra origins allowed for Server Actions (prod should include your real site URL)
ALLOWED_ORIGINS=""
ADMIN_EMAIL="erik@xeqt.co.za"
# Admin uses the same email OTP as everyone else; after sign-in, admins go to /admin. Seed default email.

# ─── Cloudflare R2 (optional — if set, uploads use R2 before Supabase; cheap storage, S3-compatible) ─
# Dashboard → R2 → Create bucket (private). Create API token with Object Read & Write.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="tagtale-uploads"

# ─── File uploads (local dev fallback only — production uses R2 or Supabase) ─
# UPLOAD_DIR="public/uploads"
