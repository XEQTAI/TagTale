# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://tagtale:tagtale@localhost:5432/tagtale?schema=public"

# ─── JWT Secret (generate: openssl rand -base64 32) ──────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ─── Email (Resend — https://resend.com) ─────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="TagTale <noreply@yourdomain.com>"

# ─── OpenRouter AI (primary — cheap Gemma 4 for moderation & generation) ─────
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxx"
# Model — set to google/gemma-4 when available; falls back to gemma-3-27b
OPENROUTER_MODEL="google/gemma-3-27b-it"

# ─── Anthropic Claude (optional — only for Managed Agents deep moderation) ───
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxx"
CLAUDE_AGENT_ID="agent_xxxxxxxxxxxxxxxx"
CLAUDE_ENVIRONMENT_ID="env_xxxxxxxxxxxxxxxx"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
ADMIN_EMAIL="admin@yourdomain.com"

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR="public/uploads"
NEXT_PUBLIC_UPLOAD_URL="/uploads"
