generator client {
  provider      = "prisma-client-js"
  // Netlify runs Linux + OpenSSL 3 (Node 20+); without this, Prisma can fail at runtime on deploy.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  avatarUrl String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  reports       Report[]
  scans         Scan[]
  objectFollows ObjectFollow[]
  createdObjects TagObject[]
}

model MagicLink {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
}

// ─── Objects ─────────────────────────────────────────────────────────────────

model TagObject {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?  // Object profile photo (taken by creator)
  qrCodeUrl   String?
  sponsorId   String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sponsor      Sponsor?      @relation(fields: [sponsorId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  scans        Scan[]
  posts        Post[]
  followers    ObjectFollow[]
  eventObjects EventObject[]

  @@index([sponsorId])
  @@index([createdById])
}

model Scan {
  id        String   @id @default(cuid())
  objectId  String
  userId    String
  latitude  Float?
  longitude Float?
  scannedAt DateTime @default(now())

  object TagObject @relation(fields: [objectId], references: [id])
  user   User      @relation(fields: [userId], references: [id])
  posts  Post[]

  @@index([objectId])
  @@index([userId])
  @@index([scannedAt])
}

model ObjectFollow {
  id          String   @id @default(cuid())
  objectId    String
  userId      String
  isFollowing Boolean  @default(true)
  createdAt   DateTime @default(now())

  object TagObject @relation(fields: [objectId], references: [id])
  user   User      @relation(fields: [userId], references: [id])

  @@unique([objectId, userId])
  @@index([userId])
}

// ─── Content ─────────────────────────────────────────────────────────────────

model Post {
  id               String    @id @default(cuid())
  objectId         String
  userId           String
  scanId           String?
  content          String?
  mediaUrl         String?
  /// Object key (e.g. userId/file.jpg) — private bucket; signed URLs in API responses
  mediaStorageKey  String?
  /// r2 | supabase — null + mediaStorageKey means legacy Supabase
  mediaStorageBackend String?
  mediaType        String?   // "image" | "video"
  views            Int       @default(0)
  moderationStatus String    @default("pending")  // "pending" | "approved" | "rejected"
  moderationNotes  String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?

  object   TagObject @relation(fields: [objectId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  scan     Scan?     @relation(fields: [scanId], references: [id])
  comments Comment[]
  likes    Like[]
  reports  Report[]

  @@index([objectId])
  @@index([userId])
  @@index([createdAt])
  @@index([moderationStatus])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
}

model Report {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  reason    String
  details   String?
  status    String   @default("pending")  // "pending" | "reviewed" | "actioned" | "dismissed"
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
  @@index([status])
}

// ─── Sponsors & Ads ──────────────────────────────────────────────────────────

model Sponsor {
  id         String   @id @default(cuid())
  name       String   @unique
  logoUrl    String?
  websiteUrl String?
  email      String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  objects   TagObject[]
  ads       Ad[]
  contacts  SponsorContact[]
  deals     SponsorDeal[]
  campaigns AdCampaign[]
}

model SponsorContact {
  id        String   @id @default(cuid())
  sponsorId String
  name      String
  email     String?
  phone     String?
  role      String?
  notes     String?
  createdAt DateTime @default(now())

  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
}

model SponsorDeal {
  id        String    @id @default(cuid())
  sponsorId String
  title     String
  value     Float?
  stage     String    @default("lead")   // lead | qualified | proposal | negotiation | won | lost
  notes     String?
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([sponsorId])
  @@index([stage])
}

model AdCampaign {
  id        String    @id @default(cuid())
  sponsorId String
  name      String
  budget    Float?
  spent     Float     @default(0)
  cpm       Float?    // cost per 1000 impressions
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("draft")  // draft | active | paused | ended
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sponsor Sponsor @relation(fields: [sponsorId], references: [id])
  ads     Ad[]

  @@index([sponsorId])
  @@index([status])
}

model Ad {
  id         String   @id @default(cuid())
  sponsorId  String?
  campaignId String?
  title      String
  imageUrl   String?
  linkUrl    String?
  cpm        Float?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  sponsor     Sponsor?     @relation(fields: [sponsorId], references: [id])
  campaign    AdCampaign?  @relation(fields: [campaignId], references: [id])
  impressions AdImpression[]

  @@index([sponsorId])
  @@index([isActive])
}

model AdImpression {
  id        String   @id @default(cuid())
  adId      String
  userId    String
  createdAt DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [id])

  @@index([adId])
  @@index([userId])
}

// ─── Events / Projects ───────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  name        String
  description String?
  location    String?
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  objects EventObject[]
}

model EventObject {
  eventId  String
  objectId String
  addedAt  DateTime @default(now())
  notes    String?

  event  Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  object TagObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@id([eventId, objectId])
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  userId    String?
  objectId  String?
  postId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([objectId])
  @@index([createdAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // "info" | "warn" | "error"
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}
